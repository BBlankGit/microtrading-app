APP_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000
DATABASE_URL=postgresql://microtrader:microtrader_password@postgres:5432/microtrading
REDIS_URL=redis://redis:6379/0
POLYGON_API_KEY=replace_me
OPENAI_API_KEY=optional_replace_me
TRADING_MODE=research
LIVE_TRADING_ENABLED=false

# Security / operational
ALLOWED_ORIGINS=http://localhost:3000
ADMIN_API_TOKEN=replace_me_for_admin_operations
EXPOSE_KEY_PREVIEW=false

# Paper simulator
PAPER_STARTING_CASH=1000
PAPER_MAX_POSITIONS=5
PAPER_MAX_TRADES_PER_DAY=100
PAPER_MAX_POSITION_SIZE_USD=250
PAPER_TAKE_PROFIT_PERCENT=0.60
PAPER_STOP_LOSS_PERCENT=0.35
PAPER_MAX_HOLD_MINUTES=15
PAPER_POLL_INTERVAL_SECONDS=60
PAPER_DEFAULT_UNIVERSE=AAPL,MSFT,NVDA,TSLA,AMD,META,AMZN,GOOGL,PLTR,SOFI
PAPER_ENTRY_SCORE_THRESHOLD=70

# Dynamic universe (Phase 2C)
PAPER_BASE_UNIVERSE=AAPL,MSFT,NVDA,TSLA,AMD,META,AMZN,GOOGL,PLTR,SOFI,SMCI,AVGO,ARM,MU,INTC,COIN,MARA,RIOT,MSTR,HOOD,RBLX,SHOP,XYZ,PYPL,UBER,LYFT,RIVN,LCID,F,GM,NIO,XPEV,LI,BABA,JD,PDD,TSM,ASML,QCOM,MRVL,CRWD,PANW,NET,DDOG,SNOW,MDB,AI,SOUN,BBAI,IONQ,RGTI,QBTS,QUBT,RKLB,LUNR,PL,SPIR,ASTS,SATL,RDW,OKLO,NNE,SMR,CCJ,UUUU,LEU,DNN,FCX,NEM,GLD,SLV,JPM,BAC,C,WFC,GS,MS,V,MA,AFRM,UPST,RDDT,SNAP,PINS,DIS,NFLX,ROKU,TTD,APP,CELH,ELF,LULU,NKE,SBUX,MCD,WMT,COST,TGT,XOM,CVX
PAPER_MAX_UNIVERSE_SIZE=150
PAPER_MAX_SYMBOLS_PER_TICK=50
PAPER_DYNAMIC_UNIVERSE_ENABLED=true
PAPER_DYNAMIC_REFRESH_SECONDS=300
PAPER_MIN_PRICE=1.00
PAPER_MAX_PRICE=1000.00
PAPER_MIN_DAY_VOLUME=500000
PAPER_MIN_CHANGE_ABS_PERCENT=0.5

# Momentum entry mode (Phase 2M — DISABLED by default; no broker, no real orders)
# Set PAPER_MOMENTUM_MODE_ENABLED=false in production. Only enable for explicit research testing.
PAPER_MOMENTUM_MODE_ENABLED=false
PAPER_MOMENTUM_ENTRY_SCORE_THRESHOLD=85
PAPER_MOMENTUM_MIN_CHANGE_PERCENT=1.5
PAPER_MOMENTUM_MIN_VOLUME_RATIO=2.0
PAPER_MOMENTUM_MAX_SPREAD_PERCENT=0.25
PAPER_MOMENTUM_REQUIRE_MARKET_RISK_ON=true
PAPER_MOMENTUM_MIN_MARKET_RISK_SCORE=60
PAPER_MOMENTUM_POSITION_SIZE_MULTIPLIER=0.5
PAPER_MOMENTUM_MAX_TRADES_PER_DAY=30

# Daily loss guard (Phase 2N — fake-money only, no broker, no real orders)
# Blocks new fake-money entries when daily P&L falls below threshold. Never prevents exits.
PAPER_DAILY_MAX_LOSS_ENABLED=true
PAPER_DAILY_MAX_LOSS_PERCENT=2.0
PAPER_DAILY_MAX_LOSS_USD=0

# Market-wide movers discovery (Phase 2J — no broker, no real orders)
PAPER_MARKET_DISCOVERY_ENABLED=true
PAPER_MARKET_DISCOVERY_MAX_SYMBOLS=100
PAPER_MARKET_DISCOVERY_REFRESH_SECONDS=300
PAPER_MARKET_DISCOVERY_INCLUDE_GAINERS=true
PAPER_MARKET_DISCOVERY_INCLUDE_LOSERS=true
PAPER_MARKET_DISCOVERY_INCLUDE_MOST_ACTIVE=true
PAPER_MARKET_DISCOVERY_MIN_PRICE=1.00
PAPER_MARKET_DISCOVERY_MAX_PRICE=1000.00
PAPER_MARKET_DISCOVERY_MIN_VOLUME=500000
PAPER_MARKET_DISCOVERY_MIN_ABS_CHANGE_PERCENT=1.0
