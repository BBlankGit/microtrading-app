APP_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000
DATABASE_URL=postgresql://microtrader:microtrader_password@postgres:5432/microtrading
REDIS_URL=redis://redis:6379/0
POLYGON_API_KEY=replace_me
OPENAI_API_KEY=optional_replace_me
TRADING_MODE=research
LIVE_TRADING_ENABLED=false

# Security / operational
ALLOWED_ORIGINS=http://localhost:3000
ADMIN_API_TOKEN=replace_me_for_admin_operations
EXPOSE_KEY_PREVIEW=false

# Paper simulator
PAPER_STARTING_CASH=1000
PAPER_MAX_POSITIONS=2
PAPER_MAX_TRADES_PER_DAY=20
PAPER_MAX_POSITION_SIZE_USD=250
PAPER_TAKE_PROFIT_PERCENT=0.60
PAPER_STOP_LOSS_PERCENT=0.35
PAPER_MAX_HOLD_MINUTES=15
PAPER_POLL_INTERVAL_SECONDS=60
PAPER_DEFAULT_UNIVERSE=AAPL,MSFT,NVDA,TSLA,AMD,META,AMZN,GOOGL,PLTR,SOFI
PAPER_ENTRY_SCORE_THRESHOLD=70

# Dynamic universe (Phase 2C)
PAPER_BASE_UNIVERSE=AAPL,MSFT,NVDA,TSLA,AMD,META,AMZN,GOOGL,PLTR,SOFI,SMCI,AVGO,ARM,MU,INTC,COIN,MARA,RIOT,MSTR,HOOD,RBLX,SHOP,SQ,PYPL,UBER,LYFT,RIVN,LCID,F,GM,NIO,XPEV,LI,BABA,JD,PDD,TSM,ASML,QCOM,MRVL,CRWD,PANW,NET,DDOG,SNOW,MDB,AI,SOUN,BBAI,IONQ,RGTI,QBTS,QUBT,RKLB,LUNR,PL,SPIR,ASTS,SATL,RDW,OKLO,NNE,SMR,CCJ,UUUU,LEU,DNN,FCX,NEM,GLD,SLV,JPM,BAC,C,WFC,GS,MS,V,MA,AFRM,UPST,RDDT,SNAP,PINS,DIS,NFLX,ROKU,TTD,APP,CELH,ELF,LULU,NKE,SBUX,MCD,WMT,COST,TGT,XOM,CVX
